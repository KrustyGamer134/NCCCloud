# NCC Agent — environment variables
# Copy this file to .env and fill in every value before running.
#
# NEVER commit .env to git — it contains the plaintext API key.
# This file (.env.example) is safe to commit: it has no real values.
#
# First-run note:
#   API_KEY is required only on the first run to register the agent.
#   After registration the permanent credentials are written to agent_state.json
#   and API_KEY can be left blank on subsequent runs.

# ---------------------------------------------------------------------------
# Backend connection
# ---------------------------------------------------------------------------

# WebSocket URL of the NCC Backend /agent/ws endpoint.
# Example: ws://your-backend-host:8000/agent/ws
# For TLS:  wss://your-backend-host/agent/ws
BACKEND_WS_URL=ws://localhost:8000/agent/ws

# HTTP URL of the NCC Backend — used for first-run registration only.
# Example: http://your-backend-host:8000
# For TLS:  https://your-backend-host
BACKEND_HTTP_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Credentials
# ---------------------------------------------------------------------------

# Bootstrap API key issued by the backend admin.
# Only required on the very first run. After registration this value is
# superseded by the key stored in agent_state.json.
# Obtain via: POST /agents/register in the NCC backend (or from the dashboard).
API_KEY=

# Agent ID — set automatically after registration. Do not set manually.
# This field is here so the agent can write it back via env if needed,
# but agent_state.json is the canonical store after first run.
AGENT_ID=

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

# Runtime environment.
# "development" — verbose logging, relaxed error handling.
# "production"  — minimal log output, strict error handling.
ENVIRONMENT=development

# Absolute path to the NCC game-server cluster root directory.
# This is the directory that the NCC core AdminAPI uses as its root.
# Example: /srv/gameservers  or  E:/GameServers
CLUSTER_ROOT=

# ---------------------------------------------------------------------------
# State file
# ---------------------------------------------------------------------------

# Path where agent_id and api_key are persisted after registration.
# The file is created automatically on first run. Keep it secret (chmod 600).
# Default: agent_state.json (in the working directory)
AGENT_STATE_FILE=agent_state.json

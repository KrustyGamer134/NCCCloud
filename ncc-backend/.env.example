# NCC Backend — environment variables
# Copy this file to .env and fill in every value before running.
#
# NEVER commit .env to git — it contains secrets.
# This file (.env.example) is safe to commit: it has no real values.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Async PostgreSQL connection string.
# Must use the postgresql+asyncpg:// scheme — the runtime path uses asyncpg,
# not psycopg2. Example: postgresql+asyncpg://ncc:secret@localhost:5432/ncc
DATABASE_URL=

# ---------------------------------------------------------------------------
# Authentication (Clerk)
# ---------------------------------------------------------------------------

# JWKS endpoint of your Clerk application.
# Found in the Clerk dashboard under: API Keys → Advanced → JWKS URL
# Example: https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=

# JWT signing algorithm — must match the algorithm shown in your Clerk app.
# Leave as RS256 unless your provider uses a different algorithm.
JWT_ALGORITHM=RS256

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Public URL of this server.
# In production this is used as the CORS allow-list (only this origin is
# permitted). In development it is ignored (CORS allow-all is used instead).
# Example: https://api.yourapp.com
BACKEND_URL=http://localhost:8000

# Runtime environment.
# "development" — CORS allow-all origins, verbose error responses.
# "production"  — CORS restricted to BACKEND_URL, minimal error detail.
ENVIRONMENT=development

# Random secret used for internal signing.
# Generate once with: python -c "import secrets; print(secrets.token_hex(32))"
# Store the result here and never change it (rotating it invalidates sessions).
SECRET_KEY=

# ---------------------------------------------------------------------------
# NCC core
# ---------------------------------------------------------------------------

# Absolute path to the root of the NCC core repository.
# Used by scripts/seed_plugin_catalog.py to locate plugins/*/plugin.json.
# Example: /opt/NewControlCenter  or  C:/projects/NewControlCenter
NCC_CORE_PATH=
